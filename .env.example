# Variables d'environnement pour le Bot Lumharel
# Renommez ce fichier en .env et remplissez les valeurs

# Votre token Discord bot (à obtenir depuis https://discord.com/developers/applications)
DISCORD_TOKEN=votre_token_ici

# L'ID du serveur (Guild ID) Discord
GUILD_ID=votre_guild_id_ici

# L'ID du channel de bienvenue
WELCOME_CHANNEL_ID=votre_welcome_channel_id_ici

